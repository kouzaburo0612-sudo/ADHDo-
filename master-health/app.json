{
  "expo": {
    "name": "Master Health",
    "slug": "master-health",
    "owner": "kozaburos-team",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "masterhealth",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0C1310",
    "ios": {
      "bundleIdentifier": "com.nash.masterhealth",
      "supportsTablet": false,
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nash.masterhealth",
      "adaptiveIcon": {
        "backgroundColor": "#0C1310",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C1310",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "食事の写真からカロリーを推定するために写真ライブラリを使用します。",
          "cameraPermission": "食事の写真を撮ってカロリーを推定するためにカメラを使用します。"
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "WithingsとOura RingがApple Healthに記録した体組成・睡眠・心拍などのデータを読み取り、健康ダッシュボードとして表示するために使用します。",
          "NSHealthUpdateUsageDescription": "このアプリはヘルスケアデータの書き込みを行いません(HealthKit連携の技術要件として記載しています)。",
          "background": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2ebbbb1f-c3d9-454b-a117-87fda73eb933"
      }
    }
  }
}
