{
  "expo": {
    "name": "ADHDo",
    "slug": "adhdo",
    "owner": "kozaburos-team",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "plugins": [
      "./plugins/without-aps-environment"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kozaburookuda.adhdo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d1017",
        "foregroundImage": "./assets/splash-icon.png"
      },
      "package": "com.kozaburookuda.adhdo"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "backgroundColor": "#0d1017",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1017"
    },
    "extra": {
      "eas": {
        "projectId": "2377c7bf-b411-4fd6-b350-d767a777ae7c"
      }
    }
  }
}
